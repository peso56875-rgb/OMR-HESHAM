rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: checks if the requesting user is an admin in the profiles collection
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    // Profiles Collection
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Campaigns, News, Events, Stories, Jobs (Public read, Admin write)
    match /campaigns/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /news/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /events/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /stories/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /jobs/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Donations
    match /donations/{document} {
      allow create: if true; // Anyone can submit a donation request
      allow read: if request.auth != null && (resource.data.profile_id == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Volunteers
    match /volunteers/{document} {
      allow create: if true; // Anyone can apply
      allow read: if request.auth != null && (resource.data.profile_id == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Contacts, Job Applications, Newsletter Subscribers (Public write, Admin read/write)
    match /contacts/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /job_applications/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /newsletter_subscribers/{document} {
      allow create, update: if true; // Anyone can subscribe
      allow read, delete: if isAdmin();
    }
  }
}
